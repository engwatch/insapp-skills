#!/bin/bash
# cc — обёртка для claude с автоматическим именованием сессии
# AI-саммаризация названия через claude haiku (быстро и дёшево)
#
# Использование:
#   cc                     — интерактивный ввод промпта
#   cc "промпт в кавычках" — прямой запуск с промптом
#   cc -r / --resume / ... — пробрасывает флаги в claude как есть

# Если переданы флаги — пробрасываем в claude как есть
case "${1:-}" in
  -r|--resume|-c|--continue|--name|-n|-p|--print|-h|--help|--debug|-d)
    exec claude "$@"
    ;;
esac

gen_name() {
  local prompt="$1"
  claude -p --model haiku "Придумай КОРОТКОЕ название сессии (2-4 слова, по-русски) для этого запроса. Выведи ТОЛЬКО название, ничего больше. Запрос: ${prompt}" 2>/dev/null | head -1 | sed 's/^["\x27]*//;s/["\x27]*$//' | head -c 40
}

if [ $# -gt 0 ]; then
  # Аргументы переданы (в кавычках)
  PROMPT="$*"
else
  # Интерактивный ввод — безопасно, zsh не парсит
  printf '› '
  IFS= read -r PROMPT
  if [ -z "$PROMPT" ]; then
    exec claude
    exit 0
  fi
fi

NAME=$(gen_name "$PROMPT")
exec claude --name "${NAME:-Сессия}" "$PROMPT"
